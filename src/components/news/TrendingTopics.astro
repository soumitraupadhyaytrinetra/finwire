---
export interface Props {
  trends: Array<{
    topic: string;
    mentionCount: number;
    growthRate: number;
    category: string;
  }>;
  period: string;
}

const { trends, period } = Astro.props;
---

<div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-6">
  <h3 class="text-sm font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-5">{period}</h3>
  <div class="space-y-1">
    {trends.slice(0, 10).map((trend) => (
      <a
        href={`/search?q=${encodeURIComponent(trend.topic)}`}
        class="flex items-center justify-between py-2.5 px-3 rounded-lg hover:bg-[var(--bg-secondary)] transition-colors group"
      >
        <div class="flex items-center gap-3 min-w-0">
          <span class="text-[var(--accent)] text-sm">&#9654;</span>
          <span class="text-sm font-medium truncate group-hover:text-[var(--accent)] transition-colors">
            {trend.topic}
          </span>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <span class="text-xs text-[var(--text-tertiary)]">{trend.mentionCount}</span>
          {trend.growthRate > 0 && (
            <span class="text-xs font-semibold text-[var(--green)]">+{trend.growthRate}%</span>
          )}
        </div>
      </a>
    ))}
  </div>
</div>
