---
import { siteConfig } from "../../config";
---

<footer class="border-t border-[var(--border)] mt-16">
  <div class="app-layout py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <div class="text-lg font-bold gradient-text mb-3">{siteConfig.name}</div>
        <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">{siteConfig.description}</p>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-4">Categories</h4>
        <ul class="space-y-2">
          <li><a href="/ai" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">AI</a></li>
          <li><a href="/research" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Research</a></li>
          <li><a href="/startups" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Startups</a></li>
          <li><a href="/security" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Security</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-4">Topics</h4>
        <ul class="space-y-2">
          <li><a href="/space" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Space</a></li>
          <li><a href="/semiconductors" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Semiconductors</a></li>
          <li><a href="/robotics" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Robotics</a></li>
          <li><a href="/trending" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Trending</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-[var(--border)] mt-10 pt-8 text-center text-xs text-[var(--text-tertiary)]">
      &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
    </div>
  </div>
</footer>
