---
import { siteConfig } from "../../config";
---

<footer class="border-t border-[var(--border)] mt-16">
  <div class="app-layout py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <div class="text-lg font-bold gradient-text mb-3">{siteConfig.name}</div>
        <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">{siteConfig.description}</p>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-4">Categories</h4>
        <ul class="space-y-2">
          <li><a href="/markets" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Markets</a></li>
          <li><a href="/stocks" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Stocks</a></li>
          <li><a href="/crypto" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Crypto</a></li>
          <li><a href="/banking" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Banking</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-4">Topics</h4>
        <ul class="space-y-2">
          <li><a href="/fintech" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Fintech</a></li>
          <li><a href="/regulation" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Regulation</a></li>
          <li><a href="/economy" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Economy</a></li>
          <li><a href="/forex" class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Forex</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-[var(--border)] mt-10 pt-8 text-center text-xs text-[var(--text-tertiary)]">
      &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
    </div>
  </div>
</footer>
