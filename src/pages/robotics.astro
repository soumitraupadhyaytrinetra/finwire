---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/news/NewsCard.astro";
import { getArticlesByCategory } from "../lib/data";

const articles = getArticlesByCategory("robotics", 50);
---

<BaseLayout title="Robotics">
  <div class="mb-8">
    <h1 class="text-xs font-semibold tracking-wide uppercase text-[var(--text-tertiary)] mb-2">Robotics</h1>
    <p class="text-[var(--text-secondary)] text-sm">Automation, humanoid robots, drones, and robot software</p>
  </div>

  <div class="space-y-3">
    {articles.map((article) => (
      <NewsCard {...article} publicationDate={new Date(article.publicationDate)} />
    ))}
  </div>
</BaseLayout>
