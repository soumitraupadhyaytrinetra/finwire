---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { defaultSources } from "../../lib/rss/sources";
---

<AdminLayout title="RSS Feeds">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">RSS Feeds</h1>
  </div>

  <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-[var(--border)] bg-[var(--bg-secondary)]">
          <th class="text-left p-3 font-semibold">Source</th>
          <th class="text-left p-3 font-semibold">Category</th>
          <th class="text-left p-3 font-semibold max-md:hidden">Feed URL</th>
          <th class="text-left p-3 font-semibold">Authority</th>
        </tr>
      </thead>
      <tbody>
        {defaultSources.map((source) => (
          <tr class="border-b border-[var(--border)] hover:bg-[var(--bg-secondary)] transition-colors">
            <td class="p-3 font-medium">{source.name}</td>
            <td class="p-3">
              <span class="category-tag text-xs">{source.category}</span>
            </td>
            <td class="p-3 max-md:hidden text-[var(--text-tertiary)] max-w-xs truncate">
              {source.feedUrl}
            </td>
            <td class="p-3">{source.authority}/10</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
