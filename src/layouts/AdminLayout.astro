---
import { siteConfig } from "../config";
import "../styles/global.css";
const { title } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - {siteConfig.name} Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#F5F4ED" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body style="background:var(--bg-primary);color:var(--text-primary);font-family:Manrope,system-ui,sans-serif;">
    <div style="display:flex;min-height:100vh;">
      <aside style="width:240px;background:var(--bg-secondary);border-right:1px solid var(--border);padding:24px;">
        <div class="gradient-text" style="font-size:1.125rem;font-weight:700;margin-bottom:32px;">
          {siteConfig.name} Admin
        </div>
        <nav style="display:flex;flex-direction:column;gap:4px;">
          <a href="/admin" style="font-size:0.875rem;color:var(--text-secondary);padding:6px 12px;border-radius:8px;text-decoration:none;">Dashboard</a>
          <a href="/admin/feeds" style="font-size:0.875rem;color:var(--text-secondary);padding:6px 12px;border-radius:8px;text-decoration:none;">RSS Feeds</a>
          <a href="/admin/jobs" style="font-size:0.875rem;color:var(--text-secondary);padding:6px 12px;border-radius:8px;text-decoration:none;">Ingestion Jobs</a>
          <a href="/admin/trends" style="font-size:0.875rem;color:var(--text-secondary);padding:6px 12px;border-radius:8px;text-decoration:none;">Trends</a>
          <hr style="border-color:var(--border);margin:16px 0;" />
          <a href="/" style="font-size:0.875rem;color:var(--text-secondary);padding:6px 12px;border-radius:8px;text-decoration:none;">Back to Site</a>
        </nav>
      </aside>
      <main style="flex:1;padding:32px;">
        <slot />
      </main>
    </div>
  </body>
</html>
